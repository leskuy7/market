# Railway / production ortamında bu değişkenleri Railway Dashboard → Variables'dan ekleyin.

# Zorunlu: MongoDB bağlantı URI (Railway MongoDB eklentisi veya MongoDB Atlas)
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/market?retryWrites=true&w=majority

# Zorunlu: JWT imza anahtarı (güçlü, rastgele bir string)
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Opsiyonel: JWT token süresi (varsayılan: 7d)
JWT_EXPIRE=7d

# Opsiyonel: Port (Railway otomatik atar)
PORT=5000

# Opsiyonel: Ortam
NODE_ENV=production
